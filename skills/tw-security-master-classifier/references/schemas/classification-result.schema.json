{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "classification-result.schema.json",
  "title": "ClassificationRecord",
  "type": "object",
  "required": ["identity", "classification", "dates", "observation", "lifecycle_events", "evidence", "conflicts", "caveats"],
  "properties": {
    "identity": {
      "type": "object",
      "required": ["security_code", "security_name_zh", "security_name_en", "isin", "cfi"],
      "additionalProperties": false,
      "properties": {
        "security_code": {"type": ["string", "null"]},
        "security_name_zh": {"type": ["string", "null"]},
        "security_name_en": {"type": ["string", "null"]},
        "isin": {"type": ["string", "null"]},
        "cfi": {"type": ["string", "null"]}
      }
    },
    "classification": {
      "type": "object",
      "required": ["asset_class", "instrument_family", "instrument_type", "market", "board", "listed_common_stock_core_flag", "classification_status", "cfi_mapping_version", "cfi_mapping_scope", "cfi_decode_depth", "reason_codes", "conflicts"],
      "properties": {
        "classification_status": {"enum": ["confirmed_dual_lane", "confirmed_official_single_lane", "provisional_single_lane", "quarantine_conflict", "quarantine_unknown"]},
        "listed_common_stock_core_flag": {"type": "boolean"},
        "cfi_mapping_version": {"type": "string"},
        "cfi_mapping_scope": {"const": "partial_controlled_prefixes_not_full_iso_10962"},
        "cfi_decode_depth": {"const": "category_or_group_prefix_only"},
        "reason_codes": {"type": "array", "items": {"type": "string"}},
        "conflicts": {"type": "array"}
      },
      "additionalProperties": true
    },
    "dates": {"type": "object"},
    "observation": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {"enum": ["observed_in_capture", "observed_in_latest_verified_snapshot", "fixture_observation_only", "historical_capture"]},
        "observed_at": {"type": ["string", "null"], "format": "date-time"},
        "source_updated_date": {"type": ["string", "null"], "format": "date"}
      },
      "additionalProperties": false
    },
    "lifecycle_events": {"type": "array"},
    "evidence": {"type": "array"},
    "conflicts": {"type": "array"},
    "caveats": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
