{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "batch-classification-report.schema.json",
  "title": "BatchClassificationReport",
  "type": "object",
  "required": ["operation", "record_count", "records", "caveats"],
  "properties": {
    "operation": {"const": "classify_all"},
    "record_count": {"type": "integer", "minimum": 0},
    "records": {"type": "array"},
    "caveats": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
