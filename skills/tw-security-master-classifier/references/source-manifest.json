        "alternate_csv": "https://mopsfin.twse.com.tw/opendata/t187ap47_L.csv",
        "grain": "fund_product",
        "declared_update_frequency": "monthly",
        "key_fields": ["fund_code", "fund_name_zh", "fund_name_en", "fund_type", "tracked_index", "inception_date", "listing_date", "manager", "custodian"],
