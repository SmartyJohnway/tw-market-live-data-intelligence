        "zh": "https://isin.twse.com.tw/isin/C_public.jsp?strMode={mode}",
        "en": "https://isin.twse.com.tw/isin/e_C_public.jsp?strMode={mode}"
      },
      "modes": [
        {"mode": 1, "collection": "public_unlisted", "zh_title": "本國未上市，未上櫃公開發行證券，國際證券辨識號碼一覽表", "primary_date_semantic": "issue_date", "verification": "payload_verified"},
        {"mode": 2, "collection": "twse_listed_mixed", "zh_title": "本國上市證券國際證券辨識號碼一覽表", "primary_date_semantic": "listing_date", "verification": "indexed_and_title_verified"},
        {"mode": 3, "collection": "listed_otc_bonds", "zh_title": "本國上市債券，上櫃債券，國際證券辨識號碼一覽表", "primary_date_semantic": "issue_and_maturity_dates", "verification": "indexed_and_title_verified"},
        {"mode": 4, "collection": "tpex_listed_mixed", "zh_title": "本國上櫃證券國際證券辨識號碼一覽表", "primary_date_semantic": "listing_date", "verification": "indexed_and_title_verified"},
        {"mode": 5, "collection": "emerging", "zh_title": "本國興櫃證券國際證券辨識號碼一覽表", "primary_date_semantic": "registration_or_listing_date", "verification": "indexed_and_title_verified"},
        {"mode": 6, "collection": "futures_options", "zh_title": "本國期貨及選擇權國際證券辨識號碼一覽表", "primary_date_semantic": "listing_date", "verification": "indexed_and_title_verified"},
        {"mode": 7, "collection": "open_ended_funds", "zh_title": "本國開放式證券投資信託基金，國際證券辨識號碼一覽表", "primary_date_semantic": "issue_date", "verification": "indexed_and_title_verified"},
        {"mode": 8, "collection": "gisa", "zh_title": "本國未公開發行之創櫃板證券國際證券辨識號碼一覽表", "primary_date_semantic": "registration_date", "verification": "indexed_and_title_verified"},
        {"mode": 9, "collection": "gold_spot", "zh_title": "登錄買賣黃金現貨國際證券辨識號碼一覽表", "primary_date_semantic": "listing_date", "verification": "payload_verified"},
        {"mode": 10, "collection": "foreign_currency_ncd", "zh_title": "外幣計價可轉讓定期存單，國際證券辨識號碼一覽表", "primary_date_semantic": "issue_date", "verification": "payload_or_index_verified"},
        {"mode": 11, "collection": "domestic_indices", "zh_title": "本國指數國際證券辨識號碼一覽表", "primary_date_semantic": "announcement_date", "verification": "indexed_and_title_verified"},
        {"mode": 12, "collection": "sto", "zh_title": "本國具證券性質之虛擬通貨(STO)國際證券辨識號碼一覽表", "primary_date_semantic": "issue_and_maturity_dates", "verification": "indexed_and_title_verified"}
      ]
