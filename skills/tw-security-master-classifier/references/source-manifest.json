        "grain": "issuer",
        "declared_update_frequency": "monthly",
        "key_fields": ["company_code", "company_name", "industry", "date_of_incorporation", "date_of_listing", "preferred_stock_shares", "english_abbreviation", "issue_shares"],
        "payload_contract": {"expected_json_type": "array", "required_fields_any": ["公司代號", "公司名稱", "出表日期"], "minimum_record_count": 1, "error_signatures": ["error", "rate limit", "maintenance", "系統維護"]},
