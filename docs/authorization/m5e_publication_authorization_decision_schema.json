{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "acknowledgement_required": {
      "const": true
    },
    "allowed_action": {
      "const": "publish_frontend_market_context"
    },
    "authorization_id": {
      "pattern": "^[A-Za-z0-9_.:-]+$",
      "type": "string"
    },
    "candidate_dir": {
      "const": "research/staging/m5d/m5d_frontend_publication_candidate_01"
    },
    "candidate_manifest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "destination": {
      "const": "frontend/public/market-context.json"
    },
    "expires_at_epoch": {
      "minimum": 1,
      "type": "integer"
    },
    "forbidden_behaviors": {
      "additionalProperties": false,
      "properties": {
        "generated_write": {
          "const": false
        },
        "network_market_data_call": {
          "const": false
        },
        "production_ready": {
          "const": false
        },
        "publication_performed": {
          "const": false
        },
        "realtime_claim": {
          "const": false
        },
        "recommendation_output": {
          "const": false
        },
        "trading_output": {
          "const": false
        }
      },
      "required": [
        "production_ready",
        "generated_write",
        "network_market_data_call",
        "trading_output",
        "recommendation_output",
        "realtime_claim",
        "publication_performed"
      ],
      "type": "object"
    },
    "frontend_baseline_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "m5c_lineage_hashes": {
      "additionalProperties": false,
      "properties": {
        "m5c_frontend_readonly_context_package_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "m5c_manifest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "m5c_run_summary_destination_correction_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        "m5c_supplemental_audit_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "m5c_manifest_sha256",
        "m5c_frontend_readonly_context_package_sha256",
        "m5c_supplemental_audit_sha256",
        "m5c_run_summary_destination_correction_sha256"
      ],
      "type": "object"
    },
    "operator_acknowledged": {
      "const": true
    },
    "single_use_id": {
      "pattern": "^[A-Za-z0-9_.:-]+$",
      "type": "string"
    },
    "token_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    }
  },
  "required": [
    "authorization_id",
    "allowed_action",
    "candidate_dir",
    "candidate_manifest_sha256",
    "m5c_lineage_hashes",
    "destination",
    "frontend_baseline_sha256",
    "expires_at_epoch",
    "single_use_id",
    "acknowledgement_required",
    "operator_acknowledged",
    "forbidden_behaviors",
    "token_sha256"
  ],
  "type": "object"
}
