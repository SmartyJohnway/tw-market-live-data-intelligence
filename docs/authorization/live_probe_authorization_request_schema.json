{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/tw-market-live-data-intelligence/live_probe_authorization_request_schema.json",
  "title": "M5A bounded controlled live probe authorization request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "requested_by",
    "requested_at",
    "expires_at",
    "source_id",
    "targets",
    "target_mode",
    "max_targets",
    "proposed_probe_script",
    "proposed_output_directory",
    "purpose",
    "required_caveats",
    "source_risk_flags",
    "network_authorized",
    "live_probe_authorized",
    "production_write",
    "frontend_publication",
    "generated_artifact_write",
    "full_market_scan",
    "trading_signal",
    "authorization_token_issued"
  ],
  "properties": {
    "request_id": {"type": "string", "pattern": "^m5a-[a-z0-9][a-z0-9._-]{2,80}$"},
    "requested_by": {"type": "string", "minLength": 1, "maxLength": 120},
    "requested_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "source_id": {"type": "string", "enum": ["TWSE_OpenAPI", "TPEx_OpenAPI", "TWSE_MIS", "Yahoo_Finance"]},
    "targets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {"type": "string", "enum": ["2330", "0050", "00929", "8069", "TAIEX"]}
    },
    "target_mode": {"const": "bounded"},
    "max_targets": {"const": 5},
    "proposed_probe_script": {"type": "string", "minLength": 1},
    "proposed_output_directory": {"type": "string", "minLength": 1},
    "purpose": {"type": "string", "minLength": 20, "maxLength": 1000},
    "required_caveats": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
    "source_risk_flags": {"type": "array", "uniqueItems": true, "items": {"type": "string"}},
    "network_authorized": {"const": false},
    "live_probe_authorized": {"const": false},
    "production_write": {"const": false},
    "frontend_publication": {"const": false},
    "generated_artifact_write": {"const": false},
    "full_market_scan": {"const": false},
    "trading_signal": {"const": false},
    "authorization_token_issued": {"const": false}
  }
}
