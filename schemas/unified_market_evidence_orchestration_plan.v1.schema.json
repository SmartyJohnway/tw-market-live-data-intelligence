{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:tw-market-live-data-intelligence:unified_market_evidence_orchestration_plan:v1",
  "title": "Unified Market Evidence Orchestration Plan v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "plan_id", "plan_hash", "execution_authorized", "input_bindings", "planner_metadata", "plan_status", "operations", "batch_groups", "accounting", "warnings", "blocked_operations", "omitted_optional_capabilities", "evidence_references", "package_approval_requirements"],
  "properties": {
    "schema_version": {"const": "unified_market_evidence_orchestration_plan.v1"},
    "plan_id": {"type": "string", "pattern": "^umeop-v1-[0-9a-f]{20}$"},
    "plan_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "execution_authorized": {"const": false},
    "input_bindings": {"$ref": "#/definitions/input_bindings"},
    "planner_metadata": {"$ref": "#/definitions/planner_metadata"},
    "plan_status": {"enum": ["plan_ready", "plan_ready_with_warnings", "plan_only_not_executable", "blocked", "requires_clarification", "unsupported"]},
    "operations": {"type": "array", "items": {"$ref": "#/definitions/operation"}},
    "batch_groups": {"type": "array", "items": {"$ref": "#/definitions/batch_group"}},
    "accounting": {"$ref": "#/definitions/accounting"},
    "warnings": {"type": "array", "items": {"$ref": "#/definitions/warning"}},
    "blocked_operations": {"type": "array", "items": {"$ref": "#/definitions/blocked_operation"}},
    "omitted_optional_capabilities": {"type": "array", "items": {"$ref": "#/definitions/omission"}},
    "evidence_references": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "package_approval_requirements": {"$ref": "#/definitions/package_approval_requirements"}
  },
  "definitions": {
    "sha": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_bindings": {"type": "object", "additionalProperties": false, "required": ["original_request_hash", "normalized_request_hash", "f3_validation_output_hash", "security_master_evidence_references", "security_master_artifact_hashes", "capability_catalog_hash", "planner_version", "routing_matrix_version", "routing_matrix_hash", "handoff_contract_version", "handoff_contract_hash"], "properties": {"original_request_hash": {"$ref": "#/definitions/sha"}, "normalized_request_hash": {"$ref": "#/definitions/sha"}, "f3_validation_output_hash": {"$ref": "#/definitions/sha"}, "security_master_evidence_references": {"type": "array", "items": {"type": "string", "minLength": 1}}, "security_master_artifact_hashes": {"type": "array", "minItems": 1, "items": {"$ref": "#/definitions/sha"}}, "capability_catalog_hash": {"$ref": "#/definitions/sha"}, "planner_version": {"type": "string", "minLength": 1}, "routing_matrix_version": {"type": "string", "minLength": 1}, "routing_matrix_hash": {"$ref": "#/definitions/sha"}, "handoff_contract_version": {"type": "string", "minLength": 1}, "handoff_contract_hash": {"$ref": "#/definitions/sha"}}},
    "planner_metadata": {"type": "object", "additionalProperties": false, "required": ["planning_timestamp", "offline", "deterministic", "limit_source"], "properties": {"planning_timestamp": {"type": "string", "format": "date-time", "pattern": "Z$"}, "offline": {"const": true}, "deterministic": {"const": true}, "limit_source": {"type": "string", "minLength": 1}}},
    "operation": {"type": "object", "additionalProperties": false, "required": ["operation_id", "capability_id", "canonical_target_ids", "market", "security_types", "parameters", "executor_id", "batch_group_id", "operation_status", "network_required", "capability_requires_execution_approval", "expected_evidence_contract", "blocking_reason_codes", "warnings", "executor_invocation_eligible"], "properties": {"operation_id": {"type": "string", "pattern": "^umeop-op-v1-[0-9a-f]{20}$"}, "capability_id": {"type": "string", "minLength": 1}, "canonical_target_ids": {"type": "array", "items": {"type": "string", "minLength": 1}}, "market": {"type": ["string", "null"]}, "security_types": {"type": "array", "items": {"type": "string"}}, "parameters": {"type": "object"}, "executor_id": {"type": ["string", "null"]}, "batch_group_id": {"type": ["string", "null"], "pattern": "^umeop-batch-v1-[0-9a-f]{20}$"}, "operation_status": {"enum": ["executable_pending_approval", "plan_only_not_executable"]}, "network_required": {"type": "boolean"}, "capability_requires_execution_approval": {"type": "boolean"}, "expected_evidence_contract": {"type": "string", "minLength": 1}, "blocking_reason_codes": {"type": "array", "maxItems": 0}, "warnings": {"type": "array", "items": {"$ref": "#/definitions/warning"}}, "executor_invocation_eligible": {"type": "boolean"}}, "allOf": [{"if": {"properties": {"operation_status": {"const": "executable_pending_approval"}}}, "then": {"properties": {"executor_id": {"type": "string", "minLength": 1}, "batch_group_id": {"type": "string"}, "executor_invocation_eligible": {"const": true}}}}, {"if": {"properties": {"operation_status": {"const": "plan_only_not_executable"}}}, "then": {"properties": {"batch_group_id": {"const": null}, "network_required": {"const": false}, "executor_invocation_eligible": {"const": false}}}}]},
    "blocked_operation": {"type": "object", "additionalProperties": false, "required": ["capability_id", "canonical_target_ids", "market", "parameters", "executor_id", "batch_group_id", "network_required", "expected_evidence_contract", "blocking_reason_codes", "executor_invocation_eligible"], "properties": {"capability_id": {"type": "string", "minLength": 1}, "canonical_target_ids": {"type": "array", "items": {"type": "string"}}, "market": {"type": ["string", "null"]}, "parameters": {"type": "object"}, "executor_id": {"type": ["string", "null"]}, "batch_group_id": {"const": null}, "network_required": {"const": false}, "expected_evidence_contract": {"type": "string", "minLength": 1}, "blocking_reason_codes": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}}, "executor_invocation_eligible": {"const": false}}},
    "batch_group": {"type": "object", "additionalProperties": false, "required": ["batch_group_id", "executor_id", "capability_id", "market", "operation_ids", "network_required", "capability_requires_execution_approval"], "properties": {"batch_group_id": {"type": "string", "pattern": "^umeop-batch-v1-[0-9a-f]{20}$"}, "executor_id": {"type": "string", "minLength": 1}, "capability_id": {"type": "string", "minLength": 1}, "market": {"type": "string", "minLength": 1}, "operation_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^umeop-op-v1-[0-9a-f]{20}$"}}, "network_required": {"const": true}, "capability_requires_execution_approval": {"type": "boolean"}}},
    "accounting": {"type": "object", "additionalProperties": false, "required": ["logical_operation_count", "batch_group_count", "executor_invocation_count", "network_request_estimate", "planned_evidence_bundle_count"], "properties": {"logical_operation_count": {"type": "integer", "minimum": 0}, "batch_group_count": {"type": "integer", "minimum": 0}, "executor_invocation_count": {"type": "integer", "minimum": 0}, "network_request_estimate": {"type": ["integer", "null"], "minimum": 0}, "planned_evidence_bundle_count": {"enum": [0, 1]}}},
    "warning": {"type": "object", "additionalProperties": false, "required": ["code", "capability_id", "canonical_target_ids", "severity", "omission_reason"], "properties": {"code": {"type": "string", "minLength": 1}, "capability_id": {"type": "string", "minLength": 1}, "canonical_target_ids": {"type": "array", "items": {"type": "string"}}, "severity": {"type": "string", "minLength": 1}, "omission_reason": {"type": "string", "minLength": 1}, "display_text": {"type": "string"}}},
    "omission": {"type": "object", "additionalProperties": false, "required": ["capability_id", "canonical_target_ids", "reason_code", "severity", "normalized_parameters"], "properties": {"capability_id": {"type": "string", "minLength": 1}, "canonical_target_ids": {"type": "array", "items": {"type": "string"}}, "reason_code": {"type": "string", "minLength": 1}, "severity": {"type": "string", "minLength": 1}, "normalized_parameters": {"type": "object"}}},
    "package_approval_requirements": {"type": "object", "additionalProperties": false, "required": ["package_requires_owner_approval", "authorization_eligible", "approval_policy", "approval_reason_codes"], "properties": {"package_requires_owner_approval": {"type": "boolean"}, "authorization_eligible": {"type": "boolean"}, "approval_policy": {"type": "string", "minLength": 1}, "approval_reason_codes": {"type": "array", "items": {"type": "string"}}}}
  }
}
