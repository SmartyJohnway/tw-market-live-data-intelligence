{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "M8R EOD Expected Trade Date and Session Status Schema",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "m8r_eod_expected_trade_date_status.v1"
    },
    "market": {
      "type": "string",
      "enum": ["TWSE", "TPEX", "TAIFEX"]
    },
    "reference_time_utc": {
      "type": "string"
    },
    "reference_time_asia_taipei": {
      "type": "string"
    },
    "reference_local_date": {
      "type": "string"
    },
    "session_status": {
      "type": "string",
      "enum": [
        "regular_trading_day",
        "weekend",
        "official_holiday",
        "special_makeup_or_exception",
        "market_closed_no_session",
        "calendar_status_unresolved"
      ]
    },
    "expected_latest_completed_trade_date": {
      "type": ["string", "null"]
    },
    "actual_official_trade_date": {
      "type": ["string", "null"]
    },
    "currentness_status": {
      "type": "string",
      "enum": [
        "official_latest_completed_eod",
        "official_previous_session_eod_before_close",
        "not_yet_published_after_close",
        "market_closed_no_session",
        "unexpected_stale_eod",
        "future_trade_date_invalid",
        "calendar_status_unresolved",
        "source_trade_date_missing",
        "invalid_trade_date_format"
      ]
    },
    "calendar_source": {
      "type": "string"
    },
    "closure_source": {
      "type": "string"
    },
    "publication_grace_applied": {
      "type": "boolean"
    },
    "fallback_policy_used": {
      "type": "boolean"
    },
    "fallback_policy": {
      "type": ["string", "null"]
    },
    "caveats": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "schema_version",
    "market",
    "reference_time_utc",
    "reference_time_asia_taipei",
    "session_status",
    "expected_latest_completed_trade_date",
    "actual_official_trade_date",
    "currentness_status",
    "calendar_source",
    "closure_source",
    "publication_grace_applied",
    "fallback_policy_used",
    "caveats"
  ],
  "additionalProperties": false
}
