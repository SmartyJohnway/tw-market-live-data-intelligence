{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Unified Market Evidence Capability Catalog v1",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "unified_market_evidence_capability_catalog.v1"
    },
    "catalog_id": {
      "type": "string"
    },
    "generated_from": {
      "type": "object",
      "properties": {
        "source_capability_registry_reference": {"type": "string"},
        "activation_policy_reference": {"type": "string"}
      },
      "additionalProperties": false
    },
    "supported_markets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "support_level": {
            "type": "string",
            "enum": ["supported", "supported_with_caveats", "provisional"]
          }
        },
        "required": ["support_level"],
        "additionalProperties": false
      }
    },
    "data_need_capabilities": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "capability_id": {"type": "string"},
          "description": {"type": "string"},
          "support_status": {
            "type": "string",
            "enum": ["contract_supported", "runtime_available", "runtime_executable", "provisional", "not_yet_implemented"]
          },
          "supported_markets": {
            "type": "array",
            "items": {"type": "string"}
          },
          "provisional_markets": {
            "type": "array",
            "items": {"type": "string"}
          },
          "allowed_parameters": {
            "type": "object",
            "additionalProperties": true
          },
          "requires_target_resolution": {"type": "boolean"},
          "requires_approval_for_execution": {"type": "boolean"},
          "possible_timing_classes": {
            "type": "array",
            "items": {"type": "string"}
          },
          "possible_fallbacks": {
            "type": "array",
            "items": {"type": "string"}
          },
          "known_limitations": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "required": [
          "capability_id",
          "description",
          "support_status",
          "supported_markets",
          "provisional_markets",
          "allowed_parameters",
          "requires_target_resolution",
          "requires_approval_for_execution",
          "possible_timing_classes",
          "possible_fallbacks",
          "known_limitations"
        ],
        "additionalProperties": false
      }
    },
    "execution": {
      "type": "object",
      "properties": {
        "preview_supported": {"type": "boolean"},
        "explicit_approval_required": {"type": "boolean"},
        "one_shot_execution": {"type": "boolean"},
        "scheduler_enabled": {"type": "boolean"},
        "polling_enabled": {"type": "boolean"},
        "persistent_watchlist_mutation": {"type": "boolean"},
        "trading_enabled": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "bounds": {
      "type": "object",
      "properties": {
        "default_target_limit": {"type": "integer"},
        "hard_target_limit": {"type": "integer"},
        "default_operation_limit": {"type": "integer"},
        "hard_operation_limit": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "available_source_families": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_family": {"type": "string"},
          "timing_class": {"type": "string"},
          "market_scope": {
            "type": "array",
            "items": {"type": "string"}
          },
          "activation_status": {"type": "string"},
          "runtime_availability": {"type": "boolean"},
          "known_limitations": {
            "type": "array",
            "items": {"type": "string"}
          }
        },
        "additionalProperties": false
      }
    },
    "fallback_semantics": {
      "type": "object",
      "additionalProperties": true
    },
    "timing_classes": {
      "type": "array",
      "items": {"type": "string"}
    },
    "known_limitations": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "required": [
    "schema_version",
    "catalog_id",
    "generated_from",
    "supported_markets",
    "data_need_capabilities",
    "execution",
    "bounds",
    "fallback_semantics",
    "timing_classes",
    "known_limitations"
  ],
  "additionalProperties": false
}
